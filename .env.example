# Copy this file to ".env" and fill in (1) an AI backend and (2) Google Search.
# Both are REQUIRED: images are found via Google Custom Search, then Gemini
# verifies the license and grades quality.

# ============================================================
# 1) AI BACKEND -- Vertex AI (recommended) -> spends your $300 GCP credits
# ============================================================
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Auth (pick one):
#   - service-account JSON:  GOOGLE_APPLICATION_CREDENTIALS=/full/path/to/key.json
#   - or run once:           gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=

# (Alternative to Vertex: a Gemini Developer API key from AI Studio. Uses the
#  AI Studio prepay balance, NOT your $300. Leave blank if using Vertex above.)
GEMINI_API_KEY=

# ============================================================
# 2) GOOGLE PROGRAMMABLE SEARCH (the image source -- REQUIRED)
#    cx:  https://programmablesearchengine.google.com  (whole web + Image search)
#    key: https://console.cloud.google.com/apis/credentials  (+ enable "Custom Search API")
# ============================================================
GCSE_KEY=
GCSE_CX=

# ---- Optional model overrides ----
# GEMINI_MODEL=gemini-2.5-flash
# IMAGEN_MODEL=imagen-3.0-generate-002
