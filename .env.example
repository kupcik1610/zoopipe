# Copy this file to ".env" and fill in ONE AI backend.
# With NO backend the pipeline still runs the FREE sources (iNaturalist,
# Wikimedia, GBIF) but skips AI grading + gap generation.

# ============================================================
# OPTION A (recommended): Vertex AI -> spends your $300 GCP credits
# ============================================================
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Auth (pick one):
#   - service-account JSON:  GOOGLE_APPLICATION_CREDENTIALS=/full/path/to/key.json
#   - or run once:           gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================
# OPTION B: Gemini Developer API key (AI Studio) -- uses AI Studio prepay,
# NOT your $300. Leave blank if using Vertex above.
# ============================================================
GEMINI_API_KEY=

# ---- Optional: Google Programmable Search (extra candidate source) ----
GCSE_KEY=
GCSE_CX=

# ---- Optional model overrides ----
# GEMINI_MODEL=gemini-2.5-flash
# IMAGEN_MODEL=imagen-3.0-generate-002
